{
  "name": "@myadbox/algolia-mock-server",
  "version": "2.1.1",
  "description": "A mock server mimicking Algolia's v5 search index for e2e testing purposes",
  "author": "MyAdbox R&D",
  "license": "MIT",
  "bin": {
    "algolia-mock-server": "./bin/cli.js"
  },
  "main": "bin/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev ./src/cli.ts",
    "lint": "eslint 'src/**/*.{js,ts,tsx}' --quiet --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/node": "^20.17.11",
    "@types/search-index": "^2.1.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.0",
    "eslint": "^8.3.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^2.5.0",
    "supertest": "^7.0.0",
    "ts-node-dev": "^1.1.8",
    "tslint": "^6.1.3",
    "typescript": "^4.5.2",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "level-party": "^5.1.1",
    "search-index": "^2.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/myadbox/algoliamockserver"
  },
  "bugs": {
    "url": "https://github.com/myadbox/algoliamockserver/issues"
  },
  "keywords": [
    "alolia",
    "mock server",
    "e2e",
    "nodejs",
    "express",
    "typescript",
    "leveldown",
    "level-party"
  ]
}
